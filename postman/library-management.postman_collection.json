{
  "info": {
    "name": "Library Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Author",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/authors",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "authors"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Naguib\",\n  \"lastName\": \"Mahfouz\",\n  \"nationality\": \"Egyptian\"\n}"
        }
      }
    },
    {
      "name": "Create Book",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/books",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "books"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Cairo Trilogy\",\n  \"isbn\": \"ISBN-6001\",\n  \"genre\": \"Novel\",\n  \"publishedYear\": \"1956\",\n  \"authorId\": 1\n}"
        }
      }
    },
    {
      "name": "Create Member",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/members",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "members"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Ali\",\n  \"lastName\": \"Hassan\",\n  \"email\": \"ali@example.com\",\n  \"phoneNumber\": \"01000000000\"\n}"
        }
      }
    },
    {
      "name": "Borrow Book",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/borrow-records",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "borrow-records"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"memberId\": 1,\n  \"bookId\": 1\n}"
        }
      }
    },
    {
      "name": "Return Book",
      "request": {
        "method": "PUT",
        "url": {
          "raw": "{{baseUrl}}/api/borrow-records/1/return",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "borrow-records",
            "1",
            "return"
          ]
        }
      }
    },
    {
      "name": "Get Active Borrows",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/borrow-records/active",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "borrow-records",
            "active"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ]
}
