          }
        },
        {
          "name": "Get Borrow Record By ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/borrow-records/1", "host": ["{{baseUrl}}"], "path": ["api", "borrow-records", "1"] }
          }
        },
