{
  "info": {
    "name": "Library Management API - Full CRUD",
    "description": "Complete API collection for Library Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authors",
      "item": [
        {
          "name": "Create Author",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/authors", "host": ["{{baseUrl}}"], "path": ["api", "authors"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Naguib\",\n  \"lastName\": \"Mahfouz\",\n  \"nationality\": \"Egyptian\",\n  \"birthDate\": \"1911-12-11\"\n}"
            }
          }
        },
        {
          "name": "Get All Authors",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/authors", "host": ["{{baseUrl}}"], "path": ["api", "authors"] }
          }
        },
        {
          "name": "Get Author By ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/authors/1", "host": ["{{baseUrl}}"], "path": ["api", "authors", "1"] }
          }
        },
        {
          "name": "Get Books By Author",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/authors/1/books", "host": ["{{baseUrl}}"], "path": ["api", "authors", "1", "books"] }
          }
        },
        {
          "name": "Update Author",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/authors/1", "host": ["{{baseUrl}}"], "path": ["api", "authors", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Naguib\",\n  \"lastName\": \"Mahfouz\",\n  \"nationality\": \"Egyptian\",\n  \"birthDate\": \"1911-12-11\"\n}"
            }
          }
        },
        {
          "name": "Delete Author",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/authors/1", "host": ["{{baseUrl}}"], "path": ["api", "authors", "1"] }
          }
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "name": "Create Book",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/books", "host": ["{{baseUrl}}"], "path": ["api", "books"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Cairo Trilogy\",\n  \"isbn\": \"ISBN-6001\",\n  \"genre\": \"Novel\",\n  \"publishedYear\": 1956,\n  \"authorId\": 1\n}"
            }
          }
        },
        {
          "name": "Get All Books",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/books", "host": ["{{baseUrl}}"], "path": ["api", "books"] }
          }
        },
        {
          "name": "Get Book By ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/books/1", "host": ["{{baseUrl}}"], "path": ["api", "books", "1"] }
          }
        },
        {
          "name": "Search Books by Title",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/books/search?title=Cairo",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books", "search"],
              "query": [{ "key": "title", "value": "Cairo" }]
            }
          }
        },
        {
          "name": "Update Book",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/books/1", "host": ["{{baseUrl}}"], "path": ["api", "books", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Cairo Trilogy - Updated\",\n  \"isbn\": \"ISBN-6001\",\n  \"genre\": \"Historical Fiction\",\n  \"publishedYear\": 1957,\n  \"authorId\": 1\n}"
            }
          }
        },
        {
          "name": "Delete Book",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/books/1", "host": ["{{baseUrl}}"], "path": ["api", "books", "1"] }
          }
        }
      ]
    },
